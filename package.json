{
    "name": "website",
    "version": "0.0.1",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "postbuild": "svelte-sitemap",
        "preview": "pnpm run build && wrangler pages dev",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "format": "prettier --check .",
        "format:fix": "prettier --write .",
        "gen": "pnpm run gen:cf-types; pnpm run gen:images",
        "gen:cf-types": "wrangler types src/worker-config.d.ts",
        "gen:images": "tsx ./scripts/gen-images.ts",
        "deploy": "pnpm run build && wrangler pages deploy"
    },
    "devDependencies": {
        "@catppuccin/tailwindcss": "1.0.0",
        "@eslint/compat": "^2.0.2",
        "@eslint/js": "^10.0.1",
        "@poppanator/sveltekit-svg": "^6.0.0",
        "@sveltejs/adapter-cloudflare": "^7.2.6",
        "@sveltejs/enhanced-img": "^0.10.3",
        "@sveltejs/kit": "^2.43.7",
        "@sveltejs/vite-plugin-svelte": "^6.2.0",
        "@tailwindcss/typography": "^0.5.16",
        "@tailwindcss/vite": "^4.1.13",
        "@typescript-eslint/eslint-plugin": "^8.44.0",
        "@typescript-eslint/parser": "^8.44.0",
        "bits-ui": "^2.9.9",
        "eslint": "^9.35.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-perfectionist": "^5.4.0",
        "eslint-plugin-svelte": "^3.12.3",
        "globals": "^17.3.0",
        "lottie-web": "^5.13.0",
        "playwright": "1.58.2",
        "prettier": "^3.6.2",
        "prettier-plugin-svelte": "^3.4.0",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "sharp": "^0.34.4",
        "svelte": "^5.38.10",
        "svelte-check": "^4.3.1",
        "svelte-meta-tags": "^4.4.1",
        "svelte-sitemap": "^3.0.0",
        "svgo": "^4.0.0",
        "tailwindcss": "^4.1.13",
        "tslib": "^2.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.44.0",
        "vite": "^7.1.5",
        "vite-imagetools": "^9.0.2",
        "wrangler": "^4.69.0"
    },
    "type": "module",
    "packageManager": "pnpm@10.9.0+sha512.0486e394640d3c1fb3c9d43d49cf92879ff74f8516959c235308f5a8f62e2e19528a65cdc2a3058f587cde71eba3d5b56327c8c33a97e4c4051ca48a10ca2d5f"
}
